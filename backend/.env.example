# ================================================
# FluentFusion AI - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to version control.

# ── Application
DEBUG=true
ENVIRONMENT=development

# ── Database
DATABASE_URL=postgresql://user:password@localhost:5432/fluentfusion

# ── Redis / Celery
REDIS_URL=redis://localhost:6379

# ── JWT / Auth
SECRET_KEY=change-me-to-a-long-random-secret-key
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key
ALGORITHM=HS256
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET=fluentfusion

# ── SendGrid
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── Frontend / CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# ── Email (SMTP fallback)
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=FluentFusion AI

# ── PULSE ML Engine
PULSE_MODEL_PATH=/app/pulse_artifacts/pulse_model.pkl
PULSE_SCALER_PATH=/app/pulse_artifacts/pulse_scaler.pkl
PULSE_ENCODERS_PATH=/app/pulse_artifacts/label_encoders.pkl
PULSE_METADATA_PATH=/app/pulse_artifacts/pulse_metadata.json
PULSE_CONFIDENCE_THRESHOLD=0.55
PULSE_REEVAL_INTERVAL_HOURS=24

# ── Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ── Admin
ADMIN_EMAILS=["admin@yourdomain.com"]
