# ================================================
# FluentFusion AI - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
# ================================================

# ── App Settings
APP_NAME=FluentFusion AI
APP_VERSION=2.0.0
ENVIRONMENT=production  # Set to "production" for production deployments
DEBUG=false  # MUST be false in production!

# ── Server
HOST=0.0.0.0
PORT=8000

# ── Database (PostgreSQL)
# Example: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://fluentfusion:your_secure_password@db:5432/fluentfusion

# ── Redis
REDIS_URL=redis://redis:6379

# ── JWT (CRITICAL - Generate a secure random string for production!)
# Use: openssl rand -hex 64
JWT_SECRET_KEY=your_secure_random_64_character_hex_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS (Comma-separated list of allowed origins)
# Example: https://fluentfusion.com,https://www.fluentfusion.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Security
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ── Frontend URL (for email links, etc.)
FRONTEND_URL=https://your-domain.com

# ── Email (SMTP)
EMAIL_ENABLED=true
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password  # Use App Password for Gmail!
FROM_EMAIL=noreply@your-domain.com
FROM_NAME=FluentFusion AI

# ── AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET=fluentfusion
S3_PUBLIC_URL=https://s3.amazonaws.com/fluentfusion

# ── Stripe (for payments)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── OpenAI (for AI features)
OPENAI_API_KEY=sk-your_openai_api_key

# ── Admin
ADMIN_EMAILS=["admin@your-domain.com"]

# ── Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ── PULSE ML Engine
PULSE_MODEL_PATH=/app/pulse_artifacts/pulse_model.pkl
PULSE_SCALER_PATH=/app/pulse_artifacts/pulse_scaler.pkl
PULSE_ENCODERS_PATH=/app/pulse_artifacts/label_encoders.pkl
PULSE_METADATA_PATH=/app/pulse_artifacts/pulse_metadata.json
PULSE_CONFIDENCE_THRESHOLD=0.55
PULSE_REEVAL_INTERVAL_HOURS=24
